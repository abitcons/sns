{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true, /* Requires emitDeclarationOnly */
    "isolatedModules": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",

    /* Composite Project */
    "composite": true, /* Required for referenced projects */
    "declaration": true, /* Ensures declaration files are emitted */
    "emitDeclarationOnly": true, /* Allows 'allowImportingTsExtensions' */

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "vite.config.ts"]
}
